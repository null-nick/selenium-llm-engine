{
  "name": "grok",
  "display_name": "Grok (xAI)",
  "aliases": ["grok", "xai"],
  "service_url": "https://grok.com/c",
  "default_model": "grok-4.0",
  "allow_unlogged": true,
  "notes": "Probably the worst engine: keeps redirecting making it the slowest engine.",
  "models": {
    "grok-4.0": 256000,
    "grok-4.0-2m": 2000000,
    "unlogged": 256000,
    "default": 256000
  },
  "selectors": {
    "prompt_area": [
      "div[role='textbox'][contenteditable='true']",
      "div[contenteditable='true']",
      "textarea[aria-label*='Ask']",
      "textarea[placeholder*='What do you want to know']",
      "textarea",
      "input[aria-label*='Ask']",
      "div[aria-label*='Type your message']"
    ],
    "send_button": [
      "button[aria-label*='Send']",
      "button[title*='Send']",
      "button[data-testid*='send']",
      "div[role='button'][aria-label*='Send']",
      "button[type='submit']",
      "button:not([disabled])"
    ],
    "response_area": [
      "div.message-bubble div.response-content-markdown.markdown",
      "div.response-content-markdown.markdown",
      "div[data-testid='assistant-response']",
      "div[data-testid='message-text']",
      "div[class*='message'][class*='assistant']",
      "div[class*='response']",
      "div.message-bubble",
      "div.markdown",
      "div[dir='auto']"
    ],
    "stop": [
      "button[aria-label*='Stop']",
      "button[title*='Stop']",
      "button[aria-label*='Stop generating']",
      "div[data-testid='stop-button']",
      "div.h-10.aspect-square:not(.relative)",
      "div.h-10.aspect-square:has(svg[width='16'])"
    ]
  },
  "login_detection": {
    "url_prefix": "https://accounts.x.ai/sign-in?redirect=grok-com",
    "url_deny_keywords": ["signin", "login", "auth"],
    "login_button_xpath": "//a[contains(translate(normalize-space(.), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), 'sign in') or contains(@href, 'sign-in') or @data-slot='button']",
    "authenticated_css_selectors": [
      "textarea[aria-label='Ask Grok anything']",
      "div.message-bubble"
    ]
  }
}
